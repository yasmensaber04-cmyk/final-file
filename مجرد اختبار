# 2️⃣ TRAIN/TEST SPLIT
# =========================================================
def split_data(df: pd.DataFrame, test_size: float = 0.2):
    """فصل البيانات بناءً على المريض"""
    
    print("\n" + "="*70)
    print("✂️  TRAIN/TEST SPLIT")
    print("="*70)
    
    unique_rids = df["RID"].unique()
    last_labels = df.groupby("RID")["label"].last().values
    
    train_rids, test_rids = train_test_split(
        unique_rids,
        test_size=test_size,
        random_state=SEED,
        stratify=last_labels
    )
    
    train_df = df[df["RID"].isin(train_rids)].copy()
    test_df = df[df["RID"].isin(test_rids)].copy()
    
    print(f"✅ Train: {len(train_df)} records, {len(train_rids)} patients")
    print(f"✅ Test: {len(test_df)} records, {len(test_rids)} patients")
    print(f"✅ Class distribution (train): {train_df['label'].value_counts().to_dict()}")
    print(f"✅ Class distribution (test): {test_df['label'].value_counts().to_dict()}")
    
    return train_df, test_df

# =========================================================
# 3️⃣ BI-LSTM MODEL
# =========================================================
class AlzheimerModel(nn.Module):
    """BI-LSTM مع Attention Mechanism"""
    
    def __init__(self, input_dim, hidden=160):
        super().__init__()
        self.lstm = nn.LSTM(
            input_dim, hidden, num_layers=2, batch_first=True,
            bidirectional=True, dropout=0.4
        )
        self.layer_norm = nn.LayerNorm(hidden * 2)
        self.attn = nn.Sequential(
            nn.Linear(hidden * 2, hidden),
            nn.Tanh(),
            nn.Linear(hidden, 1)
        )
        self.classifier = nn.Sequential(
            nn.Linear(hidden * 2, 128),
            nn.ReLU(),
            nn.Dropout(0.4),
            nn.BatchNorm1d(128),
            nn.Linear(128, 3)
        )

    def forward(self, x):
        lstm_out, _ = self.lstm(x)
        lstm_out = self.layer_norm(lstm_out)
        attn_weights = torch.softmax(self.attn(lstm_out), dim=1)
        context = torch.sum(attn_weights * lstm_out, dim=1)
        return self.classifier(context), attn_weights

# =========================================================
# 4️⃣ SEQUENCE CREATION
# =========================================================
def create_sequences_dynamic(df, features, max_len=None):
    """إنشاء Sequences مع Dynamic Padding"""
    X, y, rids = [], [], []
    
    # Calculate optimal max_len
    if max_len is None:
        lengths = [len(group) for _, group in df.groupby("RID")]
        max_len = max(3, int(np.quantile(lengths, 0.75)))
    
    for rid, group in df.groupby("RID"):
        if "Years_bl" in df.columns:
            group = group.sort_values("Years_bl")
        
        data = group[features].values
        label = group["label"].values[-1]
        
        if len(data) < 1 or np.isnan(label):
            continue
            
        if len(data) < max_len:
            pad = np.tile(data[0], (max_len - len(data), 1))
            data = np.vstack([pad, data])
        else:
            data = data[-max_len:]
        
        X.append(data)
        y.append(int(label))
        rids.append(rid)
    
    if len(X) == 0:
        return None, None, None
    
    return (
        torch.tensor(np.array(X), dtype=torch.float32),
        torch.tensor(y, dtype=torch.long),
        np.array(rids)
    )

# =========================================================
# 5️⃣ EXTRACT FEATURES FROM SEQUENCES FOR XGBOOST
# =========================================================
def extract_features_from_sequences(X_seq, features_list):
    """
    استخراج features من sequences للـ XGBoost
    نستخدم: أخر قيمة + متوسط + انحراف معياري
    """
    X_extracted = []
    
    for seq in X_seq:  # seq shape: (seq_len, num_features)
        features = []
        
        # أخر قيمة (آخر زيارة)
        features.extend(seq[-1])
        
        # متوسط القيم
        features.extend(np.mean(seq, axis=0))
        
        # الانحراف المعياري
        features.extend(np.std(seq, axis=0))
        
        X_extracted.append(features)
    
    return np.array(X_extracted)

# =========================================================
# 6️⃣ TRAIN BI-LSTM
# =========================================================
def train_eval_BI_LSTM(train_df, test_df, features, seq_len=3, horizon_name="Forecast"):
    """تدريب نموذج BI-LSTM"""
    
    print(f"\n{'='*70}")
    print(f"🎯 BI-LSTM {horizon_name.upper()}")
    print(f"{'='*70}")
    
    X_train_seq, y_train_seq, _ = create_sequences_dynamic(train_df, features, seq_len)
    X_test_seq, y_test_seq, rids_test = create_sequences_dynamic(test_df, features, seq_len)
    
    if X_train_seq is None:
        print("❌ Failed to create sequences!")
        return None, None, None, None, None, None

    print(f"Train: {X_train_seq.shape}, Test: {X_test_seq.shape}")
    print(f"Classes: {np.bincount(y_train_seq.numpy())}")

    train_loader = DataLoader(TensorDataset(X_train_seq, y_train_seq), batch_size=32, shuffle=True)
    test_loader = DataLoader(TensorDataset(X_test_seq, y_test_seq), batch_size=32)

    model = AlzheimerModel(len(features)).to(DEVICE)
    
    class_weights = compute_class_weight(
        class_weight="balanced",
        classes=np.unique(y_train_seq.numpy()),
        y=y_train_seq.numpy()
    )
    weights_tensor = torch.tensor(class_weights, dtype=torch.float32).to(DEVICE)
    
    criterion = nn.CrossEntropyLoss(weight=weights_tensor)
    optimizer = torch.optim.AdamW(model.parameters(), lr=3e-4, weight_decay=1e-4)
    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(
        optimizer, mode='min', factor=0.5, patience=5
    )

    best_loss = np.inf
    patience = 0
    train_losses, val_losses = [], []
    
    for epoch in range(50):
        # Train
        model.train()
        total_loss = 0
        for bx, by in train_loader:
            bx, by = bx.to(DEVICE), by.to(DEVICE)
            optimizer.zero_grad()
            outputs, _ = model(bx)
            loss = criterion(outputs, by)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()
            total_loss += loss.item()
        
        avg_loss = total_loss / len(train_loader)
        train_losses.append(avg_loss)
        
        # Validate
        model.eval()
        val_loss = 0
        with torch.no_grad():
            for bx, by in test_loader:
                bx, by = bx.to(DEVICE), by.to(DEVICE)
                outputs, _ = model(bx)
                loss = criterion(outputs, by)
                val_loss += loss.item()
        
        avg_val_loss = val_loss / len(test_loader)
        val_losses.append(avg_val_loss)
        
        scheduler.step(avg_val_loss)
        
        if avg_val_loss < best_loss:
            best_loss = avg_val_loss
            torch.save(model.state_dict(), f"models/lstm_{horizon_name}_best.pt")
            patience = 0
        else:
            patience += 1
        
        if (epoch + 1) % 10 == 0:
            print(f"Epoch {epoch+1}/50 - Train: {avg_loss:.4f}, Val: {avg_val_loss:.4f}")
        
        if patience > 10:
            print(f"⏹️ Early stopping at epoch {epoch+1}")
            break

    # Load best model
    model.load_state_dict(torch.load(f"models/lstm_{horizon_name}_best.pt"))
    
    # Plot training curves
    plt.figure(figsize=(10, 5))
    plt.plot(train_losses, label='Train', linewidth=2)
    plt.plot(val_losses, label='Val', linewidth=2)
    plt.xlabel('Epoch')
    plt.ylabel('Loss')
    plt.title(f'BI-LSTM {horizon_name} - Training Curves')
    plt.legend()
    plt.grid(alpha=0.3)
    plt.tight_layout()
    plt.savefig(f"plots/lstm_{horizon_name}_curves.png", dpi=300, bbox_inches='tight')
    plt.close()
    
    # Evaluate
    model.eval()
    lstm_probs, attention_per_visit = [], []
    with torch.no_grad():
        for bx, _ in test_loader:
            outputs, attn_weights = model(bx.to(DEVICE))
            lstm_probs.extend(torch.softmax(outputs, 1).cpu().numpy())
            attention_per_visit.append(attn_weights.cpu().numpy())
    
    lstm_probs = np.array(lstm_probs)
    lstm_preds = np.argmax(lstm_probs, axis=1)
    
    # Extract features for XGBoost
    X_xgb_train = extract_features_from_sequences(X_train_seq.numpy(), features)
    X_xgb_test = extract_features_from_sequences(X_test_seq.numpy(), features)

    print(f"\n✅ RESULTS:")
    print(classification_report(y_test_seq.numpy(), lstm_preds, target_names=['CN', 'MCI', 'AD'], zero_division=0))
    
    try:
        auc_score = roc_auc_score(pd.get_dummies(y_test_seq.numpy()), lstm_probs, multi_class='ovr')
        print(f"AUC-ROC: {auc_score:.4f}")
    except:
        auc_score = 0.0

    return (y_test_seq.numpy(), lstm_preds, lstm_probs, 
            np.vstack(attention_per_visit), rids_test,
            X_xgb_train, X_xgb_test, y_train_seq.numpy())

# =========================================================
# 7️⃣ TRAIN XGBOOST (ON SAME DATA)
# =========================================================
def train_eval_XGBoost_on_sequences(X_train, X_test, y_train, y_test):
    """تدريب XGBoost على نفس البيانات المستخرجة من Sequences"""
    
    print(f"\n{'='*70}")
    print(f"🎯 XGBOOST (ON SEQUENCE FEATURES)")
    print(f"{'='*70}")
    
    print(f"Train: {X_train.shape}, Test: {X_test.shape}")
    print(f"Classes: {np.bincount(y_train.astype(int))}")

    model = xgb.XGBClassifier(
        n_estimators=500, max_depth=4, learning_rate=0.05,
        subsample=0.8, colsample_bytree=0.8, random_state=SEED,
        eval_metric='mlogloss'
    )
    model.fit(X_train, y_train, eval_set=[(X_test, y_test)], verbose=False)
    
    joblib.dump(model, f"models/xgb_model.pkl")

    probs = model.predict_proba(X_test)
    preds = np.argmax(probs, axis=1)

    print(f"\n✅ RESULTS:")
    print(classification_report(y_test, preds, target_names=['CN', 'MCI', 'AD'], zero_division=0))
    
    try:
        auc_score = roc_auc_score(pd.get_dummies(y_test), probs, multi_class='ovr')
        print(f"AUC-ROC: {auc_score:.4f}")
    except:
        auc_score = 0.0

    return preds, probs

# =========================================================
# 8️⃣ ENSEMBLE
# =========================================================
def ensemble_predictions(lstm_probs, xgb_probs, lstm_weight=0.6):
    """دمج التنبؤات"""
    
    final_probs = lstm_weight * lstm_probs + (1 - lstm_weight) * xgb_probs
    final_preds = np.argmax(final_probs, axis=1)
    return final_preds, final_probs

