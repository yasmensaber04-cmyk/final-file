def plot_confusion(y_true, y_pred, title, save_name):
    """رسم مصفوفة الالتباس"""
    cm = confusion_matrix(y_true, y_pred)
    plt.figure(figsize=(8, 6))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
               xticklabels=['CN', 'MCI', 'AD'],
               yticklabels=['CN', 'MCI', 'AD'],
               cbar_kws={'label': 'Count'})
    plt.title(title, fontweight='bold')
    plt.ylabel('True')
    plt.xlabel('Predicted')
    plt.tight_layout()
    plt.savefig(f"plots/{save_name}.png", dpi=300, bbox_inches='tight')
    plt.close()

def plot_attention(attn_matrix, rids, seq_len, title, save_name):
    """رسم خريطة الانتباه"""
    attn_sub = attn_matrix[:min(20, len(attn_matrix))].squeeze()
    rids_sub = rids[:min(20, len(rids))]
    
    plt.figure(figsize=(12, 8))
    sns.heatmap(attn_sub, cmap="YlOrRd",
               xticklabels=[f"V{i}" for i in range(1, seq_len+1)],
               yticklabels=rids_sub)
    plt.title(title)
    plt.xlabel('Visit')
    plt.ylabel('RID')
    plt.tight_layout()
    plt.savefig(f"plots/{save_name}.png", dpi=300, bbox_inches='tight')
    plt.close()

